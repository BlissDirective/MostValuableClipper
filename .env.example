# MVC Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git

# ============================================
# Supabase (Database + Auth)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Upstash Redis (Queue + Cache)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================
# Cloudflare R2 (Clip Storage)
# ============================================
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_API_TOKEN=your-api-token
CLOUDFLARE_R2_BUCKET=mvc-clips
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ============================================
# Fly.io (Deployment)
# ============================================
FLY_APP_NAME=mvc-backend
FLY_REGION=lax
FLY_ORG_TOKEN=your-fly-token

# ============================================
# Stripe (Payments)
# ============================================
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================
# GitHub (Repo Access + Actions)
# ============================================
GITHUB_TOKEN=ghp_...

# ============================================
# Application
# ============================================
APP_ENV=development
APP_SECRET=generate-a-random-secret-key-here
API_V1_PREFIX=/api/v1

# ============================================
# LangGraph / AI (Optional)
# ============================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Social Platform OAuth (Phase 2)
# ============================================
# TIKTOK_CLIENT_ID=
# TIKTOK_CLIENT_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
