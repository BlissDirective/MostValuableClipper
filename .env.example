# MVC Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git

# ============================================
# Supabase (Database + Auth)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DIRECT_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Frontend (Expo) — must use EXPO_PUBLIC_ prefix
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_BASE_URL=https://your-api.fly.dev/api/v1

# ============================================
# Upstash Redis (Queue + Cache)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================
# Cloudflare R2 (Clip Storage)
# ============================================
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_API_TOKEN=your-api-token
CLOUDFLARE_R2_BUCKET=mvc-clips
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ============================================
# Fly.io (Deployment)
# ============================================
FLY_APP_NAME=mvc-backend
FLY_REGION=lax
FLY_ORG_TOKEN=your-fly-token

# ============================================
# Stripe (Payments)
# ============================================
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================
# GitHub (Repo Access + Actions)
# ============================================
GITHUB_TOKEN=ghp_...
GH_TOKEN=ghp_...

# ============================================
# Application
# ============================================
APP_ENV=development
APP_SECRET=generate-a-random-secret-key-here
API_V1_PREFIX=/api/v1

# ============================================
# LLM Router - Multi-Provider API Keys
# Set keys for providers you want to use. The router will
# automatically select the cheapest available model per task.
# ============================================
ANTHROPIC_API_KEY=sk-ant-...        # Required for PREMIUM tier (hooks, edit)
OPENAI_API_KEY=sk-...               # Required for STANDARD/ECONOMY tiers
GROQ_API_KEY=gsk_...                # Optional - fastest inference (400-840 TPS)
DEEPSEEK_API_KEY=sk-...             # Optional - cheapest batch processing
GEMINI_API_KEY=...                  # Optional - Google Gemini Flash models

# ============================================
# Celery / Redis (Worker Queue)
# ============================================
REDIS_URL=redis://localhost:6379/0  # Uses Upstash in production

# ============================================
# Social Platform OAuth (Phase 2)
# ============================================
# TIKTOK_CLIENT_ID=
# TIKTOK_CLIENT_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
